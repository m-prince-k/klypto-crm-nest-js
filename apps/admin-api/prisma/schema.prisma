generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma/client/admin"
}

datasource db {
  provider = "postgresql"
  url      = env("ADMIN_DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  fullName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
